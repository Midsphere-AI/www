---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn('fixed inset-x-0 z-20 lg:hidden', className)} style="bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);" id="mobile-composer-wrapper">
  <!-- Example prompts (shown when textarea is empty) -->
  <div id="mobile-prompts" class="mx-3 mb-2">
    <button type="button" class="mobile-prompt-btn w-full border-t border-border-subtle px-4 py-2.5 text-left text-[13px] text-dark/50 transition-colors hover:text-dark/70">Build a SaaS dashboard</button>
    <button type="button" class="mobile-prompt-btn w-full border-t border-border-subtle px-4 py-2.5 text-left text-[13px] text-dark/50 transition-colors hover:text-dark/70">Design a signup flow</button>
    <button type="button" class="mobile-prompt-btn w-full border-t border-border-subtle px-4 py-2.5 text-left text-[13px] text-dark/50 transition-colors hover:text-dark/70">Create a portfolio site</button>
  </div>

  <!-- Pill composer -->
  <div class="mx-3">
    <div class="flex items-center gap-2 rounded-[28px] border border-border bg-surface p-1.5 shadow-lg">
      <!-- Tools button -->
      <button
        type="button"
        id="mobile-tools-btn"
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-dark/40 transition-colors hover:bg-elevated hover:text-dark/70"
        aria-label="Open tools"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
      </button>

      <!-- Textarea -->
      <textarea
        id="mobile-textarea"
        rows="1"
        placeholder="Ask anything"
        class="flex-1 resize-none bg-transparent py-2 text-sm text-dark placeholder:text-dark/35 outline-none"
        style="max-height: 120px;"
      ></textarea>

      <!-- Send / Voice button -->
      <div id="mobile-action-container" class="shrink-0">
        <!-- Send pill (shown when text present) -->
        <button
          type="button"
          id="mobile-send-btn"
          class="hidden h-9 items-center justify-center rounded-full bg-dark px-4 text-paper"
          aria-label="Send"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
        </button>
        <!-- Voice pill (shown when no text and voice supported) -->
        <button
          type="button"
          id="mobile-voice-btn"
          class="hidden h-9 items-center gap-1.5 rounded-full bg-elevated px-3 text-dark/60"
          aria-label="Voice input"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
          <span class="text-xs font-medium">Voice</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  function initMobileComposer() {
    var wrapper = document.getElementById('mobile-composer-wrapper');
    if (!wrapper || wrapper.dataset.initialized) return;
    wrapper.dataset.initialized = 'true';

    var textarea = document.getElementById('mobile-textarea');
    var sendBtn = document.getElementById('mobile-send-btn');
    var voiceBtn = document.getElementById('mobile-voice-btn');
    var mobilePrompts = document.getElementById('mobile-prompts');
    var promptBtns = wrapper.querySelectorAll('.mobile-prompt-btn');
    var c = window.__composer;

    // Show voice button if supported and no text
    var hasVoice = !!(window.SpeechRecognition || window.webkitSpeechRecognition);
    if (hasVoice) {
      voiceBtn.classList.remove('hidden');
      voiceBtn.classList.add('flex');
    }

    function updateButtons() {
      var hasText = textarea.value.trim().length > 0;
      if (hasText || c.state.loading) {
        sendBtn.classList.remove('hidden');
        sendBtn.classList.add('flex');
        voiceBtn.classList.add('hidden');
        voiceBtn.classList.remove('flex');
      } else {
        sendBtn.classList.add('hidden');
        sendBtn.classList.remove('flex');
        if (hasVoice) {
          voiceBtn.classList.remove('hidden');
          voiceBtn.classList.add('flex');
        }
      }

      // Show/hide mobile prompts
      if (hasText) {
        mobilePrompts.classList.add('hidden');
      } else {
        mobilePrompts.classList.remove('hidden');
      }
    }

    // Auto-resize
    function autoResize() {
      textarea.style.height = 'auto';
      textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
    }

    textarea.addEventListener('input', function() {
      autoResize();
      c.setText(textarea.value);
      updateButtons();
    });

    // Enter to submit
    textarea.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (textarea.value.trim() || c.state.files.length > 0) {
          c.submit();
        }
      }
    });

    // Send button
    sendBtn.addEventListener('click', function() {
      c.submit();
    });

    // Prompt pills
    promptBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var text = btn.textContent.trim();
        textarea.value = text;
        c.setText(text);
        autoResize();
        updateButtons();
        textarea.focus();
      });
    });

    // Sync from store
    document.addEventListener('composer:text-changed', function(e) {
      if (document.activeElement !== textarea) {
        textarea.value = e.detail.text;
        autoResize();
        updateButtons();
      }
    });

    // Loading state
    document.addEventListener('composer:loading-changed', function(e) {
      textarea.disabled = e.detail.loading;
      sendBtn.disabled = e.detail.loading;
      textarea.style.opacity = e.detail.loading ? '0.5' : '1';
      updateButtons();
    });

    // Mobile tools button opens same popover as desktop (scroll to top area)
    var mobileToolsBtn = document.getElementById('mobile-tools-btn');
    mobileToolsBtn.addEventListener('click', function() {
      // For mobile, we trigger the file input directly
      var fileInput = document.getElementById('file-input');
      if (fileInput) fileInput.click();
    });

    updateButtons();
  }

  initMobileComposer();
  document.addEventListener('astro:after-swap', initMobileComposer);
})();
</script>
