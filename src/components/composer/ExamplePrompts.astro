---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn('flex flex-col items-center gap-3', className)} id="example-prompts">
  <div class="flex items-center gap-2">
    <span class="text-xs text-dark/40">Try an example prompt</span>
    <button type="button" id="shuffle-prompts-btn" class="flex h-6 w-6 items-center justify-center rounded-md text-dark/30 transition-colors hover:bg-elevated hover:text-dark/60" aria-label="Shuffle prompts">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" x2="21" y1="20" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" x2="21" y1="15" y2="21"/><line x1="4" x2="9" y1="4" y2="9"/></svg>
    </button>
  </div>
  <div id="prompt-pills" class="flex flex-wrap items-center justify-center gap-2">
    <!-- Pills injected by JS -->
  </div>
</div>

<script is:inline>
(function() {
  var allPrompts = [
    'SaaS KPI dashboard',
    'App signup demo',
    'Meeting notes template',
    'Portfolio website',
    'Task tracker app',
  ];

  function shuffle(arr) {
    var copy = arr.slice();
    for (var i = copy.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = copy[i];
      copy[i] = copy[j];
      copy[j] = tmp;
    }
    return copy;
  }

  function renderPills(prompts) {
    var container = document.getElementById('prompt-pills');
    if (!container) return;
    container.innerHTML = '';
    prompts.forEach(function(text) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'rounded-full border border-border px-4 py-1.5 text-xs font-medium text-dark/60 transition-all duration-150 hover:border-border-strong hover:bg-elevated hover:text-dark';
      btn.textContent = text;
      btn.addEventListener('click', function() {
        var c = window.__composer;
        if (!c) return;
        c.setText(text);
        var ta = document.getElementById('composer-textarea');
        if (ta) {
          ta.value = text;
          ta.style.height = 'auto';
          ta.style.height = ta.scrollHeight + 'px';
          ta.focus();
        }
      });
      container.appendChild(btn);
    });
  }

  function initPrompts() {
    var container = document.getElementById('example-prompts');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    var shown = shuffle(allPrompts).slice(0, 3);
    renderPills(shown);

    var shuffleBtn = document.getElementById('shuffle-prompts-btn');
    if (shuffleBtn) {
      shuffleBtn.addEventListener('click', function() {
        shown = shuffle(allPrompts).slice(0, 3);
        renderPills(shown);
      });
    }
  }

  initPrompts();
  document.addEventListener('astro:after-swap', initPrompts);
})();
</script>
