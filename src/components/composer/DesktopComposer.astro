---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn('hidden w-full max-w-3xl lg:block', className)} id="desktop-composer-wrapper">
  <!-- Composer box -->
  <div id="desktop-composer" class="relative rounded-xl border border-border bg-surface transition-shadow duration-200 focus-within:border-accent focus-within:ring-3 focus-within:ring-accent/15">

    <!-- File preview row -->
    <div id="file-preview-row" class="hidden flex-wrap gap-2 border-b border-border-subtle px-4 pt-3 pb-2">
    </div>

    <!-- Textarea -->
    <textarea
      id="composer-textarea"
      rows="3"
      placeholder="Describe your idea, Agent will bring it to life..."
      class="w-full resize-none bg-transparent px-5 py-3.5 text-[15px] text-dark placeholder:text-dark/35 outline-none"
      style="max-height: 200px;"
    ></textarea>

    <!-- Bottom toolbar -->
    <div class="flex items-center justify-between px-3 pb-3">
      <div class="flex items-center gap-1">
        <!-- Tools [+] button -->
        <button
          type="button"
          id="tools-toggle-btn"
          class="flex h-8 w-8 items-center justify-center rounded-lg text-dark/40 transition-colors duration-150 hover:bg-elevated hover:text-dark/70"
          aria-label="Open tools"
          aria-expanded="false"
          aria-haspopup="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
        </button>

        <!-- Voice button -->
        <button
          type="button"
          id="voice-btn"
          class="hidden h-8 w-8 items-center justify-center rounded-lg text-dark/40 transition-colors duration-150 hover:bg-elevated hover:text-dark/70"
          aria-label="Voice input"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
        </button>
      </div>

      <div class="flex items-center gap-3">
        <!-- Plan badge -->
        <span class="text-xs text-dark/35">Free</span>

        <!-- Send button -->
        <button
          type="button"
          id="send-btn"
          class="flex h-8 w-8 items-center justify-center rounded-lg bg-dark text-paper transition-opacity duration-150 disabled:opacity-25"
          aria-label="Send"
          disabled
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
        </button>
      </div>
    </div>

    <!-- Tools strip -->
    <div id="tools-strip" class="flex items-center justify-between rounded-b-xl border-t border-border-subtle bg-elevated/50 px-4 py-2">
      <a href="/connectors" class="text-xs text-dark/40 transition-colors hover:text-dark/60">Connect your tools to Midsphere</a>
      <div class="flex items-center gap-1">
        <div class="flex -space-x-1.5">
          <!-- GitHub -->
          <div class="flex h-5 w-5 items-center justify-center rounded-full bg-dark/80 ring-1 ring-surface">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <!-- Slack -->
          <div class="flex h-5 w-5 items-center justify-center rounded-full bg-purple-600 ring-1 ring-surface">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.163 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.163 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.163 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.27a2.527 2.527 0 0 1-2.52-2.523 2.527 2.527 0 0 1 2.52-2.52h6.315A2.528 2.528 0 0 1 24 15.163a2.528 2.528 0 0 1-2.522 2.523h-6.315z"/></svg>
          </div>
          <!-- Gmail -->
          <div class="flex h-5 w-5 items-center justify-center rounded-full bg-red-500 ring-1 ring-surface">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/></svg>
          </div>
          <!-- Notion -->
          <div class="flex h-5 w-5 items-center justify-center rounded-full bg-dark ring-1 ring-surface">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L17.86 1.968c-.42-.326-.98-.7-2.055-.607L2.84 2.298c-.466.046-.56.28-.374.466l2.007 1.444zm.793 3.08v13.904c0 .747.373 1.027 1.214.98l14.523-.84c.841-.046.934-.56.934-1.166V6.354c0-.606-.233-.933-.747-.886l-15.177.886c-.56.047-.747.327-.747.934zm14.337.745c.093.42 0 .84-.42.888l-.7.14v10.264c-.608.327-1.168.514-1.635.514-.747 0-.934-.234-1.495-.933l-4.577-7.186v6.952l1.448.327s0 .84-1.168.84l-3.222.186c-.093-.186 0-.653.327-.746l.84-.233V8.12L7.97 7.934c-.094-.42.14-1.026.793-1.073l3.456-.233 4.764 7.279v-6.44l-1.215-.14c-.093-.514.28-.886.747-.933l3.222-.187z"/></svg>
          </div>
          <!-- Linear -->
          <div class="flex h-5 w-5 items-center justify-center rounded-full bg-indigo-600 ring-1 ring-surface">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M2.652 14.13l7.218 7.218a10.064 10.064 0 0 1-7.218-7.218zM1.26 11.2a10.096 10.096 0 0 0 .703 3.32L11.52 4.963a10.096 10.096 0 0 0-3.32-.703L1.26 11.2zm2.883 7.436l9.493-9.493A10.137 10.137 0 0 0 12.04 4.08L2.547 13.573c.296 1.86 1.05 3.492 2.143 4.863h0l-.547.2zM7.355 20.672l9.882-9.882a10.17 10.17 0 0 0-2.158-3.205L5.95 16.715a10.17 10.17 0 0 0 1.405 3.957zM12.8 22.74l7.94-7.94c-.247-1.7-.896-3.24-1.84-4.56L9.78 19.36c1.32.944 2.86 1.593 4.56 1.84l-1.54 1.54zM15.87 22.477L22.477 15.87A10.064 10.064 0 0 0 20.038 12l-7.718 7.718a10.064 10.064 0 0 0 3.55 2.759z"/></svg>
          </div>
        </div>
        <button type="button" id="dismiss-tools-strip" class="ml-2 flex h-5 w-5 items-center justify-center rounded text-dark/30 transition-colors hover:text-dark/60" aria-label="Dismiss">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Tools Popover -->
    <div id="tools-popover" class="absolute bottom-full left-0 z-40 mb-2 hidden w-80 max-h-[60vh] overflow-y-auto rounded-xl border border-border bg-surface shadow-lg">
      <!-- Attach files -->
      <button type="button" id="attach-files-btn" class="flex w-full items-center gap-3 px-4 py-3 text-left transition-colors hover:bg-elevated">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-elevated">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-dark/60"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
        </div>
        <div>
          <div class="text-sm font-medium text-dark">Attach files</div>
          <div class="text-[11px] text-dark/40">Upload images, documents, up to 50MB</div>
        </div>
      </button>

      <div class="mx-4 border-t border-border-subtle"></div>

      <!-- Addons -->
      <div class="px-4 py-3">
        <div class="mb-2 flex items-center gap-2">
          <span class="text-xs font-medium text-dark/50">Addons</span>
          <span id="addons-count" class="hidden rounded-full bg-accent/15 px-1.5 py-0.5 text-[10px] font-semibold text-accent"></span>
        </div>
        <div id="addons-list" class="flex flex-wrap gap-1.5">
          <span class="text-[11px] text-dark/35">No authorized addons. <a href="/connectors" class="underline underline-offset-2">Install from Connectors.</a></span>
        </div>
      </div>

      <div class="mx-4 border-t border-border-subtle"></div>

      <!-- MCPs -->
      <div class="px-4 py-3">
        <div class="mb-2 flex items-center gap-2">
          <span class="text-xs font-medium text-dark/50">MCPs</span>
          <span id="mcps-count" class="hidden rounded-full bg-accent/15 px-1.5 py-0.5 text-[10px] font-semibold text-accent"></span>
        </div>
        <div id="mcps-list">
          <span class="text-[11px] text-dark/35">No custom MCPs configured. <a href="/settings" class="underline underline-offset-2">Add in Settings.</a></span>
        </div>
      </div>
    </div>

    <!-- Hidden file input -->
    <input type="file" id="file-input" class="hidden" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.csv,.json,.md" />
  </div>
</div>

<script is:inline>
(function() {
  function initDesktopComposer() {
    var wrapper = document.getElementById('desktop-composer-wrapper');
    if (!wrapper || wrapper.dataset.initialized) return;
    wrapper.dataset.initialized = 'true';

    var textarea = document.getElementById('composer-textarea');
    var sendBtn = document.getElementById('send-btn');
    var toolsBtn = document.getElementById('tools-toggle-btn');
    var toolsPopover = document.getElementById('tools-popover');
    var voiceBtn = document.getElementById('voice-btn');
    var attachBtn = document.getElementById('attach-files-btn');
    var fileInput = document.getElementById('file-input');
    var filePreviewRow = document.getElementById('file-preview-row');
    var toolsStrip = document.getElementById('tools-strip');
    var dismissStrip = document.getElementById('dismiss-tools-strip');
    var c = window.__composer;

    // Show voice button if supported
    if (window.SpeechRecognition || window.webkitSpeechRecognition) {
      voiceBtn.classList.remove('hidden');
      voiceBtn.classList.add('flex');
    }

    // --- Textarea auto-resize ---
    function autoResize() {
      textarea.style.height = 'auto';
      textarea.style.height = Math.min(textarea.scrollHeight, 200) + 'px';
    }

    textarea.addEventListener('input', function() {
      autoResize();
      c.setText(textarea.value);
      sendBtn.disabled = !textarea.value.trim() && c.state.files.length === 0;
    });

    // --- Keyboard handling ---
    textarea.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (textarea.value.trim() || c.state.files.length > 0) {
          c.submit();
        }
      }
    });

    // --- Paste handling ---
    textarea.addEventListener('paste', function(e) {
      var items = (e.clipboardData || e.originalEvent.clipboardData).items;
      var hasFiles = false;

      for (var i = 0; i < items.length; i++) {
        if (items[i].kind === 'file') {
          var file = items[i].getAsFile();
          if (file) {
            hasFiles = true;
            addFileFromInput(file);
          }
        }
      }

      // Large text paste → file
      if (!hasFiles) {
        var text = e.clipboardData.getData('text/plain');
        if (text && text.length > 5000) {
          e.preventDefault();
          var blob = new Blob([text], { type: 'text/plain' });
          var file = new File([blob], 'pasted-text.txt', { type: 'text/plain' });
          addFileFromInput(file);
        }
      }
    });

    // --- Send button ---
    sendBtn.addEventListener('click', function() {
      c.submit();
    });

    // --- File handling ---
    function addFileFromInput(file) {
      var reader = new FileReader();
      var fileObj = {
        name: file.name,
        type: file.type,
        size: file.size,
        preview: null,
      };

      if (file.type.startsWith('image/')) {
        reader.onload = function(e) {
          fileObj.preview = e.target.result;
          c.addFile(fileObj);
        };
        reader.readAsDataURL(file);
      } else {
        c.addFile(fileObj);
      }
    }

    attachBtn.addEventListener('click', function() {
      fileInput.click();
      toolsPopover.classList.add('hidden');
      toolsBtn.setAttribute('aria-expanded', 'false');
    });

    fileInput.addEventListener('change', function() {
      for (var i = 0; i < fileInput.files.length; i++) {
        addFileFromInput(fileInput.files[i]);
      }
      fileInput.value = '';
    });

    // --- File preview rendering ---
    function getFileIcon(type) {
      if (type.startsWith('image/')) return '\uD83D\uDDBC\uFE0F';
      if (type.startsWith('video/')) return '\uD83C\uDFAC';
      if (type.startsWith('audio/')) return '\uD83C\uDFB5';
      if (type === 'application/pdf') return '\uD83D\uDCC4';
      if (type.includes('spreadsheet') || type.includes('csv')) return '\uD83D\uDCCA';
      if (type.includes('text') || type.includes('json') || type.includes('javascript')) return '\uD83D\uDCCB';
      return '\uD83D\uDCCE';
    }

    function renderFilePreview() {
      var files = c.state.files;
      if (files.length === 0) {
        filePreviewRow.classList.add('hidden');
        filePreviewRow.classList.remove('flex');
        return;
      }
      filePreviewRow.classList.remove('hidden');
      filePreviewRow.classList.add('flex');
      filePreviewRow.innerHTML = '';

      files.forEach(function(f, idx) {
        var badge = document.createElement('div');
        badge.className = 'group inline-flex items-center gap-2 rounded-lg border border-border-subtle bg-elevated/60 px-2 py-1.5';

        var thumb = '';
        if (f.preview) {
          thumb = '<img src="' + f.preview + '" class="h-8 w-8 rounded object-cover" alt="" />';
        } else {
          thumb = '<span class="flex h-8 w-8 items-center justify-center rounded bg-elevated text-sm">' + getFileIcon(f.type) + '</span>';
        }

        badge.innerHTML = thumb +
          '<div class="flex flex-col">' +
            '<span class="max-w-[120px] truncate text-xs font-bold text-dark">' + f.name + '</span>' +
            '<span class="text-[10px] text-dark/40">' + c.formatFileSize(f.size) + '</span>' +
          '</div>' +
          '<button type="button" class="ml-1 hidden h-5 w-5 items-center justify-center rounded-full bg-dark/10 text-dark/50 transition-colors hover:bg-dark/20 group-hover:flex" aria-label="Remove file">' +
            '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>' +
          '</button>';

        var removeBtn = badge.querySelector('button');
        removeBtn.addEventListener('click', function() {
          c.removeFile(idx);
        });

        filePreviewRow.appendChild(badge);
      });

      sendBtn.disabled = false;
    }

    document.addEventListener('composer:files-changed', renderFilePreview);

    // --- Tools popover ---
    toolsBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isOpen = !toolsPopover.classList.contains('hidden');
      if (isOpen) {
        toolsPopover.classList.add('hidden');
        toolsBtn.setAttribute('aria-expanded', 'false');
      } else {
        toolsPopover.classList.remove('hidden');
        toolsBtn.setAttribute('aria-expanded', 'true');
      }
    });

    // Close popover on click outside
    window.addEventListener('click', function(e) {
      if (!toolsPopover.contains(e.target) && e.target !== toolsBtn) {
        toolsPopover.classList.add('hidden');
        toolsBtn.setAttribute('aria-expanded', 'false');
      }
    });

    // --- Tools strip dismiss ---
    if (dismissStrip) {
      dismissStrip.addEventListener('click', function() {
        toolsStrip.classList.add('hidden');
        c.state.toolsStripDismissed = true;
      });
    }

    // --- Loading state ---
    document.addEventListener('composer:loading-changed', function(e) {
      var loading = e.detail.loading;
      textarea.disabled = loading;
      sendBtn.disabled = loading;
      if (loading) {
        textarea.style.opacity = '0.5';
        sendBtn.innerHTML = '<svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"/><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="opacity-75"/></svg>';
      } else {
        textarea.style.opacity = '1';
        sendBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>';
      }
    });

    // --- Sync from store (for deep-link pre-fill) ---
    document.addEventListener('composer:text-changed', function(e) {
      if (document.activeElement !== textarea) {
        textarea.value = e.detail.text;
        autoResize();
        sendBtn.disabled = !e.detail.text.trim() && c.state.files.length === 0;
      }
    });

    // --- Voice input ---
    var recognition = null;
    voiceBtn.addEventListener('click', function() {
      if (c.state.recording) {
        if (recognition) recognition.stop();
        return;
      }

      var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) return;

      recognition = new SpeechRecognition();
      recognition.continuous = true;
      recognition.interimResults = true;

      c.state.recording = true;
      voiceBtn.classList.add('bg-danger/15', 'text-danger');
      voiceBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>';

      recognition.onresult = function(event) {
        var transcript = '';
        for (var i = 0; i < event.results.length; i++) {
          transcript += event.results[i][0].transcript;
        }
        textarea.value = transcript;
        c.setText(transcript);
        autoResize();
        sendBtn.disabled = !transcript.trim();
      };

      recognition.onend = function() {
        c.state.recording = false;
        voiceBtn.classList.remove('bg-danger/15', 'text-danger');
        voiceBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>';
        recognition = null;
      };

      recognition.start();
    });

    // Read query params after all components are initialized
    setTimeout(function() {
      if (c.readQueryParams) c.readQueryParams();
      // Focus textarea if pre-filled
      if (c.state.text) {
        textarea.value = c.state.text;
        autoResize();
        sendBtn.disabled = false;
        textarea.focus();
      }
    }, 50);
  }

  initDesktopComposer();
  document.addEventListener('astro:after-swap', initDesktopComposer);
})();
</script>
