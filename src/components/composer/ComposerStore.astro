<!-- Global state store for the composer. Must be rendered before all other composer components. -->
<script is:inline>
(function() {
  if (window.__composer) return;

  var state = {
    text: '',
    files: [],
    addons: [],
    mcps: [],
    mode: null,
    loading: false,
    recording: false,
    toolsOpen: false,
    toolsStripDismissed: false,
  };

  function emit(name, detail) {
    document.dispatchEvent(new CustomEvent('composer:' + name, { detail: detail }));
  }

  function setText(val) {
    state.text = val;
    emit('text-changed', { text: val });
  }

  function addFile(file) {
    state.files.push(file);
    emit('files-changed', { files: state.files });
  }

  function removeFile(index) {
    state.files.splice(index, 1);
    emit('files-changed', { files: state.files });
  }

  function setMode(mode) {
    state.mode = mode;
    emit('mode-changed', { mode: mode });
  }

  function toggleAddon(id) {
    var idx = state.addons.indexOf(id);
    if (idx === -1) state.addons.push(id);
    else state.addons.splice(idx, 1);
    emit('config-changed', { addons: state.addons, mcps: state.mcps });
  }

  function toggleMCP(id) {
    var idx = state.mcps.indexOf(id);
    if (idx === -1) state.mcps.push(id);
    else state.mcps.splice(idx, 1);
    emit('config-changed', { addons: state.addons, mcps: state.mcps });
  }

  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function submit() {
    if (state.loading) return;
    if (!state.text.trim() && state.files.length === 0) return;

    state.loading = true;
    emit('loading-changed', { loading: true });

    var prompt = state.text.trim();
    if (state.mode) {
      prompt = '[' + state.mode + '] ' + prompt;
    }

    var payload = { prompt: prompt };
    if (state.files.length > 0) payload.files = state.files;
    if (state.addons.length > 0) payload.addons = state.addons;
    if (state.mcps.length > 0) payload.mcp_configs = state.mcps;

    console.log('[Composer] Submit:', payload);

    // Stub: simulate API call
    setTimeout(function() {
      state.loading = false;
      emit('loading-changed', { loading: false });
      // In production: POST to API, then navigate to /chat/{id}
      // window.location.href = '/chat/' + response.conversation_id;
    }, 1500);
  }

  // Read URL query params for deep-link handoff
  function readQueryParams() {
    var params = new URLSearchParams(window.location.search);
    var prompt = params.get('prompt');
    var mode = params.get('mode');
    var addons = params.get('addons');
    var autosubmit = params.get('autosubmit');

    if (prompt) {
      setText(decodeURIComponent(prompt));
    }
    if (mode && ['web', 'mobile', 'design', 'slides', 'animation'].indexOf(mode) !== -1) {
      setMode(mode);
    }
    if (addons) {
      addons.split(',').forEach(function(id) {
        if (id.trim()) toggleAddon(id.trim());
      });
    }

    // Strip params from URL
    if (prompt || mode || addons) {
      window.history.replaceState({}, '', window.location.pathname);
    }

    // Auto-submit after hydration
    if (autosubmit === 'true' && prompt) {
      setTimeout(function() { submit(); }, 300);
    }
  }

  window.__composer = {
    state: state,
    emit: emit,
    setText: setText,
    addFile: addFile,
    removeFile: removeFile,
    setMode: setMode,
    toggleAddon: toggleAddon,
    toggleMCP: toggleMCP,
    formatFileSize: formatFileSize,
    submit: submit,
    readQueryParams: readQueryParams,
  };
})();
</script>
