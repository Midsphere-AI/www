---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn('relative hidden lg:block', className)} id="project-switcher">
  <button
    type="button"
    id="project-switcher-btn"
    class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1.5 text-sm text-dark/70 transition-colors hover:border-border-strong hover:bg-elevated"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-dark/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
    <span class="max-w-[180px] truncate">Default workspace</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-dark/30"><path d="m6 9 6 6 6-6"/></svg>
  </button>

  <!-- Dropdown -->
  <div id="project-dropdown" class="absolute left-1/2 top-full z-30 mt-2 hidden w-64 -translate-x-1/2 rounded-xl border border-border bg-surface shadow-lg">
    <div class="p-2">
      <button type="button" class="project-item flex w-full items-center gap-2.5 rounded-lg bg-accent/10 px-3 py-2 text-left text-sm text-dark">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        Default workspace
      </button>
    </div>
    <div class="mx-2 border-t border-border-subtle"></div>
    <div class="p-2">
      <a href="#" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-dark/60 transition-colors hover:bg-elevated hover:text-dark">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
        New project
      </a>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  function initProjectSwitcher() {
    var container = document.getElementById('project-switcher');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    var btn = document.getElementById('project-switcher-btn');
    var dropdown = document.getElementById('project-dropdown');

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('hidden');
    });

    window.addEventListener('click', function(e) {
      if (!container.contains(e.target)) {
        dropdown.classList.add('hidden');
      }
    });
  }

  initProjectSwitcher();
  document.addEventListener('astro:after-swap', initProjectSwitcher);
})();
</script>
