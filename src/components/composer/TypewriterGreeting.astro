---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn('text-center', className)}>
  <h1 class="text-xl font-normal tracking-tight text-dark md:text-3xl lg:text-4xl">
    <span id="greeting-text" aria-label="Greeting"></span><span id="greeting-cursor" class="ml-0.5 inline-block font-light opacity-60" style="animation: cursorBlink 0.7s step-end infinite;">|</span>
  </h1>
</div>

<script is:inline>
(function() {
  function initGreeting() {
    var el = document.getElementById('greeting-text');
    var cursor = document.getElementById('greeting-cursor');
    if (!el || el.dataset.initialized) return;
    el.dataset.initialized = 'true';

    var fullText = 'Your hardest problems, solved autonomously.';
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
      el.textContent = fullText;
      el.setAttribute('aria-label', fullText);
      return;
    }

    var i = 0;
    el.textContent = '';
    el.setAttribute('aria-label', fullText);

    function type() {
      if (i < fullText.length) {
        el.textContent += fullText.charAt(i);
        i++;
        setTimeout(type, 38);
      }
    }
    // Small initial delay for page paint
    setTimeout(type, 200);
  }

  initGreeting();
  document.addEventListener('astro:after-swap', initGreeting);
})();
</script>
