---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const templates = [
  { id: 'web', label: 'Website' },
  { id: 'mobile', label: 'Mobile' },
  { id: 'design', label: 'Design' },
  { id: 'slides', label: 'Slides' },
  { id: 'animation', label: 'Animation' },
];
---

<div class={cn('flex items-center justify-center gap-4 lg:gap-6', className)} id="template-carousel">
  {templates.map((t) => (
    <button
      type="button"
      data-mode={t.id}
      class="group flex flex-col items-center gap-1.5 outline-none template-btn"
      aria-label={`${t.label} template`}
    >
      <div class="flex h-11 w-11 items-center justify-center rounded-full border border-border bg-surface text-dark/50 transition-all duration-150 group-hover:border-accent group-hover:bg-accent/10 group-hover:text-accent">
        {t.id === 'web' && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        )}
        {t.id === 'mobile' && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
        )}
        {t.id === 'design' && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 8 4.5v7L12 22l-8-8.5v-7z"/><path d="m12 8 4 2.5v3.5L12 16l-4-2v-3.5z"/></svg>
        )}
        {t.id === 'slides' && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="14" x="3" y="3" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
        )}
        {t.id === 'animation' && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        )}
      </div>
      <span class="text-xs font-medium text-dark/50 transition-colors duration-150 group-hover:text-dark">{t.label}</span>
    </button>
  ))}
</div>

<script is:inline>
(function() {
  function initCarousel() {
    var container = document.getElementById('template-carousel');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    var buttons = container.querySelectorAll('.template-btn');
    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var mode = btn.getAttribute('data-mode');
        var c = window.__composer;
        if (!c) return;

        // Toggle mode
        if (c.state.mode === mode) {
          c.setMode(null);
        } else {
          c.setMode(mode);
        }

        // If text exists, submit immediately
        if (c.state.text.trim()) {
          c.submit();
        } else {
          // Focus the textarea
          var ta = document.getElementById('composer-textarea');
          if (ta) ta.focus();
        }
      });
    });

    // Listen for mode changes to update active state
    document.addEventListener('composer:mode-changed', function(e) {
      var activeMode = e.detail.mode;
      buttons.forEach(function(btn) {
        var isActive = btn.getAttribute('data-mode') === activeMode;
        var circle = btn.querySelector('div');
        if (isActive) {
          circle.classList.add('border-accent', 'bg-accent/10', 'text-accent');
          circle.classList.remove('border-border', 'bg-surface', 'text-dark/50');
        } else {
          circle.classList.remove('border-accent', 'bg-accent/10', 'text-accent');
          circle.classList.add('border-border', 'bg-surface', 'text-dark/50');
        }
      });
    });
  }

  initCarousel();
  document.addEventListener('astro:after-swap', initCarousel);
})();
</script>
