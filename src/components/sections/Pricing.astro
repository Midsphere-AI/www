---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: '/mo',
    desc: 'Get started with the basics.',
    highlighted: false,
    cta: 'Start free',
  },
  {
    name: 'Lite',
    price: '$9',
    period: '/mo',
    desc: 'For individuals shipping real work.',
    highlighted: true,
    cta: 'Get Lite',
  },
  {
    name: 'Pro',
    price: '$19',
    period: '/mo',
    desc: 'For power users and small teams.',
    highlighted: false,
    cta: 'Get Pro',
  },
];

type FeatureValue = string | boolean;

interface FeatureRow {
  label: string;
  values: [FeatureValue, FeatureValue, FeatureValue];
}

const features: FeatureRow[] = [
  { label: 'Tasks per week', values: ['1', '5', '15'] },
  { label: 'Connectors', values: ['6', '12', '24'] },
  { label: 'Sandbox duration', values: ['1 hr', '24 hr', 'Unlimited'] },
  { label: 'Custom LLM', values: [false, true, true] },
  { label: 'Scheduled tasks', values: [false, '1', '3'] },
  { label: 'Custom MCPs', values: [false, false, '4'] },
  { label: 'Own E2B sandbox', values: [false, false, true] },
  { label: 'Support', values: ['Email', 'Email', 'Priority'] },
];
---

<section id="pricing" class={cn('section-divider py-14 lg:py-20', className)} aria-labelledby="pricing-heading">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 lg:mb-10" data-animate>
      <span class="text-[12px] font-medium tracking-wide text-dark/50">Pricing</span>
      <h2 id="pricing-heading" class="mt-2 text-xl font-normal tracking-tight text-dark md:text-3xl lg:text-4xl">
        Simple, transparent pricing
      </h2>
    </div>

    <!-- Desktop: three columns -->
    <div class="hidden md:grid md:grid-cols-3 md:gap-0" data-animate data-delay="1">
      {tiers.map((tier, ti) => (
        <div class={cn(
          'flex flex-col px-6 py-8 lg:px-8 lg:py-10',
          ti === 1 && 'border-x border-dark/[0.06]',
        )}>
          {/* Plan name */}
          <div class="flex items-center gap-2">
            <span class="text-[12px] font-medium tracking-wide text-dark/50">{tier.name}</span>
            {tier.highlighted && (
              <span class="rounded bg-dark px-1.5 py-0.5 text-[9px] font-medium tracking-wide text-paper">Popular</span>
            )}
          </div>

          {/* Price */}
          <div class="mt-4 flex items-baseline gap-0.5">
            <span class="text-5xl font-normal tracking-tight lg:text-6xl">{tier.price}</span>
            <span class="text-sm text-dark/40">{tier.period}</span>
          </div>
          <p class="mt-2 text-[13px] text-dark/60">{tier.desc}</p>

          {/* CTA */}
          <a
            href="https://platform.midsphere.ai/login"
            class={cn(
              'mt-6 block rounded-lg py-2.5 text-center text-[13px] font-medium transition-colors duration-200',
              tier.highlighted
                ? 'bg-dark text-paper hover:bg-dark/85'
                : 'ring-1 ring-dark/[0.1] text-dark hover:bg-subtle',
            )}
          >
            {tier.cta}
          </a>

          {/* Features */}
          <ul class="mt-8 space-y-3 border-t border-dark/[0.06] pt-6" role="list">
            {features.map((row) => {
              const val = row.values[ti];
              const included = val !== false;
              return (
                <li class={cn(
                  'flex items-start gap-2 text-[13px]',
                  included ? 'text-dark/55' : 'text-dark/20',
                )}>
                  {included ? (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-dark/30" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  ) : (
                    <span class="mt-0.5 flex h-3.5 w-3.5 shrink-0 items-center justify-center">
                      <span class="block h-px w-2 bg-dark/12"></span>
                    </span>
                  )}
                  <span>{typeof val === 'boolean' ? row.label : `${val} ${row.label.toLowerCase()}`}</span>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    <!-- Mobile: stacked -->
    <div class="space-y-10 md:hidden" data-animate data-delay="1">
      {tiers.map((tier, ti) => (
        <div class={cn(ti > 0 && 'border-t border-dark/[0.06] pt-10')}>
          <div class="flex items-center gap-2">
            <span class="text-[12px] font-medium tracking-wide text-dark/50">{tier.name}</span>
            {tier.highlighted && (
              <span class="rounded bg-dark px-1.5 py-0.5 text-[9px] font-medium tracking-wide text-paper">Popular</span>
            )}
          </div>
          <div class="mt-3 flex items-baseline gap-0.5">
            <span class="text-5xl font-normal tracking-tight">{tier.price}</span>
            <span class="text-sm text-dark/40">{tier.period}</span>
          </div>
          <p class="mt-2 text-[13px] text-dark/60">{tier.desc}</p>
          <a
            href="https://platform.midsphere.ai/login"
            class={cn(
              'mt-5 block rounded-lg py-2.5 text-center text-[13px] font-medium transition-colors duration-200',
              tier.highlighted
                ? 'bg-dark text-paper hover:bg-dark/85'
                : 'ring-1 ring-dark/[0.1] text-dark hover:bg-subtle',
            )}
          >
            {tier.cta}
          </a>
          <ul class="mt-6 space-y-2.5" role="list">
            {features.map((row) => {
              const val = row.values[ti];
              if (val === false) return null;
              return (
                <li class="flex items-start gap-2 text-[13px] text-dark/55">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-dark/30" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{typeof val === 'boolean' ? row.label : `${val} ${row.label.toLowerCase()}`}</span>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    <!-- Trust line -->
    <p class="mt-12 text-[11px] text-dark/25" data-animate data-delay="2">
      All plans include SSL encryption, OAuth integrations, and isolated sandbox environments. No credit card required.
    </p>
  </div>
</section>
