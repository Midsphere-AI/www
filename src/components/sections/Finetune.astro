---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const aspects = [
  {
    label: 'Choose your LLM',
    description: 'Swap in GPT-4o, Claude, Gemini, Llama, or any OpenAI-compatible model.',
    tag: 'BYO Model',
  },
  {
    label: 'Custom MCP servers',
    description: 'Plug in your own tool servers — private APIs, internal databases, or bespoke logic.',
    tag: 'Pro',
  },
  {
    label: 'System prompts',
    description: 'Define persona, constraints, and domain expertise with editable instructions.',
    tag: 'All plans',
  },
  {
    label: 'Sandbox environment',
    description: 'Configure CPU, RAM, disk, and runtime — or bring your own E2B sandbox.',
    tag: 'Configurable',
  },
  {
    label: 'Connector permissions',
    description: 'Grant read-only or read-write access per integration. Scope what your agent can touch.',
    tag: 'Granular',
  },
  {
    label: 'Output format',
    description: 'JSON, Markdown, CSV, HTML — define the structure of every response.',
    tag: 'Flexible',
  },
] as const;
---

<section id="finetune" class={cn('section-divider py-8 lg:py-14', className)} aria-labelledby="finetune-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 lg:mb-10" data-animate>
      <h2 id="finetune-heading" class="text-3xl font-semibold leading-[0.95] tracking-tight sm:text-4xl lg:text-5xl">
        Finetune every aspect of your agent
      </h2>
      <p class="mt-3 max-w-2xl text-base text-dark/60 sm:text-lg">
        Midsphere isn't a black box. Swap models, wire in custom tools, shape behaviour — make it yours.
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-animate data-delay="1">
      {aspects.map((aspect) => (
        <div class="rounded-xl bg-subtle/80 border border-dark/[0.08] p-5 transition-all duration-300 ease-out hover:bg-subtle hover:shadow-md hover:border-dark/[0.12] hover:-translate-y-0.5">
          <div class="flex items-center justify-between gap-2 mb-2">
            <h3 class="text-base font-semibold">{aspect.label}</h3>
            <span class="shrink-0 rounded-full bg-dark/[0.04] px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-dark/40">
              {aspect.tag}
            </span>
          </div>
          <p class="text-sm text-dark/50">{aspect.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
