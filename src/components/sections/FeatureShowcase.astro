---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const features = [
  {
    title: 'Deep Research',
    heroText: 'Deep Research',
    tag: 'Analysis',
    description: 'Analyze hundreds of sources in minutes. Structured, cited reports on any topic.',
    colors: { bg: '#E8573A', light: '#F09080', dark: '#C23A1E', accent: '#FBBBA8' },
  },
  {
    title: 'Full-Stack Builder',
    heroText: 'Full-Stack Builder',
    tag: 'Development',
    description: 'Describe your app and Midsphere builds it — frontend, backend, database, deploy.',
    colors: { bg: '#6C5CE7', light: '#A29BFE', dark: '#5241D0', accent: '#D4CFFF' },
  },
  {
    title: 'Workflow Automation',
    heroText: 'Workflow Automation',
    tag: 'Automation',
    description: 'Connect your tools and automate repetitive work across 500+ platforms.',
    colors: { bg: '#00B894', light: '#55E6C1', dark: '#009B7D', accent: '#B8F0E0' },
  },
  {
    title: 'Smart Integrations',
    heroText: 'Smart Integrations',
    tag: '500+ Apps',
    description: 'Slack, GitHub, Google Sheets, Notion, Linear — connected via OAuth.',
    colors: { bg: '#0984E3', light: '#74B9FF', dark: '#0767B5', accent: '#BDE0FF' },
  },
  {
    title: 'Sandboxed Execution',
    heroText: 'Sandboxed Execution',
    tag: 'Security',
    description: 'Every task runs in an isolated cloud environment. Safe data, clean code.',
    colors: { bg: '#2D3436', light: '#636E72', dark: '#1A1D1E', accent: '#B2BEC3' },
  },
] as const;
---

<section id="feature-showcase" class={cn('section-divider py-14 lg:py-20', className)} aria-labelledby="showcase-heading">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 lg:mb-10" data-animate>
      <span class="text-[12px] font-medium tracking-wide text-dark/50">Capabilities</span>
      <h2 id="showcase-heading" class="mt-2 text-xl font-normal tracking-tight text-dark md:text-3xl lg:text-4xl">
        What makes Midsphere powerful
      </h2>
    </div>
  </div>

  <!-- Carousel -->
  <div class="relative" data-animate data-delay="1">
    <!-- Arrows (desktop) -->
    <button
      type="button"
      class="showcase-arrow showcase-arrow-left absolute left-4 top-1/2 z-10 hidden -translate-y-1/2 lg:flex h-10 w-10 items-center justify-center rounded-full bg-paper/90 border border-dark/[0.08] shadow-sm backdrop-blur-sm transition-all duration-200 hover:bg-paper hover:shadow-md hover:scale-105 active:scale-95"
      aria-label="Scroll left"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button
      type="button"
      class="showcase-arrow showcase-arrow-right absolute right-4 top-1/2 z-10 hidden -translate-y-1/2 lg:flex h-10 w-10 items-center justify-center rounded-full bg-paper/90 border border-dark/[0.08] shadow-sm backdrop-blur-sm transition-all duration-200 hover:bg-paper hover:shadow-md hover:scale-105 active:scale-95"
      aria-label="Scroll right"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <!-- Scrollable track -->
    <div
      class="showcase-track hide-scrollbar flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory px-[max(1rem,calc((100vw-72rem)/2+1.5rem))]"
      role="region"
      aria-label="Feature showcase carousel"
      tabindex="0"
    >
      {features.map((feature, i) => (
        <article
          class="showcase-card group relative w-[260px] shrink-0 snap-center overflow-hidden rounded-2xl transition-all duration-500 ease-out hover:-translate-y-1.5 hover:shadow-2xl lg:w-[280px]"
          data-card-index={i}
          style={`--card-bg: ${feature.colors.bg}; --card-light: ${feature.colors.light}; --card-dark: ${feature.colors.dark}; --card-accent: ${feature.colors.accent};`}
        >
          {/* Colored background */}
          <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${feature.colors.light}, ${feature.colors.bg} 40%, ${feature.colors.dark});`} aria-hidden="true"></div>

          {/* Abstract geometric shapes — unique per card */}
          <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
            {/* Card 0: Diagonal lines + pendulum circle */}
            {i === 0 && (
              <>
                <div class="absolute -right-8 -top-8 h-[200%] w-px rotate-[30deg] origin-top" style="background: rgba(255,255,255,0.12);"></div>
                <div class="absolute -right-4 -top-8 h-[200%] w-px rotate-[30deg] origin-top" style="background: rgba(255,255,255,0.08);"></div>
                <div class="absolute right-[30%] top-[8%] h-px w-[60%] rotate-[30deg]" style="background: rgba(255,255,255,0.2);"></div>
                <div class="absolute right-[32%] top-[12%] h-4 w-4 rounded-full" style={`background: ${feature.colors.dark}; box-shadow: 0 0 20px ${feature.colors.dark};`}></div>
                <div class="absolute left-0 top-0 h-full w-1/2" style={`background: linear-gradient(135deg, ${feature.colors.light}66 0%, transparent 60%);`}></div>
              </>
            )}

            {/* Card 1: Overlapping rectangles */}
            {i === 1 && (
              <>
                <div class="absolute left-[10%] top-[15%] h-[55%] w-[45%] rounded-2xl" style={`background: ${feature.colors.dark}44;`}></div>
                <div class="absolute left-[30%] top-[10%] h-[55%] w-[45%] rounded-2xl" style={`background: ${feature.colors.light}44;`}></div>
                <div class="absolute right-[8%] top-[20%] h-[50%] w-[40%] rounded-2xl" style={`background: ${feature.colors.dark}33;`}></div>
                <div class="absolute left-[20%] top-[35%] h-3 w-3 rounded-full" style={`background: ${feature.colors.accent};`}></div>
              </>
            )}

            {/* Card 2: Flowing arcs */}
            {i === 2 && (
              <>
                <div class="absolute -right-[20%] top-[5%] h-[80%] w-[80%] rounded-full border-2" style={`border-color: rgba(255,255,255,0.1);`}></div>
                <div class="absolute -right-[10%] top-[15%] h-[60%] w-[60%] rounded-full border-2" style={`border-color: rgba(255,255,255,0.08);`}></div>
                <div class="absolute left-[5%] bottom-[30%] h-[40%] w-[40%] rounded-full" style={`background: ${feature.colors.dark}33;`}></div>
                <div class="absolute right-[25%] top-[20%] h-2.5 w-2.5 rounded-full" style={`background: rgba(255,255,255,0.25);`}></div>
              </>
            )}

            {/* Card 3: Grid + circles */}
            {i === 3 && (
              <>
                <div class="absolute inset-0" style={`background-image: linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 50% 50%;`}></div>
                <div class="absolute left-[40%] top-[20%] h-[45%] w-[45%] rounded-full border-2" style={`border-color: rgba(255,255,255,0.1);`}></div>
                <div class="absolute left-[50%] top-[30%] h-[25%] w-[25%] rounded-full" style={`background: ${feature.colors.dark}55;`}></div>
              </>
            )}

            {/* Card 4: Concentric rings */}
            {i === 4 && (
              <>
                <div class="absolute left-1/2 top-[35%] h-[70%] w-[70%] -translate-x-1/2 -translate-y-1/2 rounded-full border" style={`border-color: rgba(255,255,255,0.06);`}></div>
                <div class="absolute left-1/2 top-[35%] h-[50%] w-[50%] -translate-x-1/2 -translate-y-1/2 rounded-full border" style={`border-color: rgba(255,255,255,0.08);`}></div>
                <div class="absolute left-1/2 top-[35%] h-[30%] w-[30%] -translate-x-1/2 -translate-y-1/2 rounded-full border" style={`border-color: rgba(255,255,255,0.1);`}></div>
                <div class="absolute left-1/2 top-[35%] h-[12%] w-[12%] -translate-x-1/2 -translate-y-1/2 rounded-full" style={`background: rgba(255,255,255,0.08);`}></div>
                <div class="absolute right-[15%] top-[12%] h-2 w-2 rounded-full" style={`background: ${feature.colors.accent}88;`}></div>
              </>
            )}
          </div>

          {/* Big bold hero typography */}
          <div class="relative flex flex-col justify-end px-6 pt-6 pb-4 h-[200px] lg:h-[220px] lg:px-7 lg:pt-8">
            <div class="select-none text-[1.75rem] font-bold leading-[1.1] tracking-tight text-white lg:text-[2rem]" aria-hidden="true">
              {feature.heroText}
            </div>
          </div>

          {/* Bottom info strip */}
          <div class="relative px-6 pb-5 lg:px-8 lg:pb-6">
            <div class="flex items-center gap-2">
              <h3 class="text-[13px] font-semibold text-white/90">{feature.title}</h3>
              <span class="rounded-full px-2 py-0.5 text-[9px] font-semibold tracking-wide text-white/80" style={`background: rgba(0,0,0,0.25);`}>{feature.tag}</span>
            </div>
            <p class="mt-1.5 text-[12px] leading-relaxed text-white/50">{feature.description}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Dot indicators -->
    <div class="mt-6 flex items-center justify-center gap-2" aria-hidden="true">
      {features.map((_, i) => (
        <button
          type="button"
          class={cn(
            'showcase-dot rounded-full transition-all duration-300',
            i === 0 ? 'h-2 w-2 bg-dark' : 'h-1.5 w-1.5 bg-dark/20',
          )}
          data-dot-index={i}
          aria-label={`Go to card ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .hide-scrollbar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function initShowcase() {
    const track = document.querySelector('.showcase-track');
    const cards = document.querySelectorAll('.showcase-card');
    const dots = document.querySelectorAll('.showcase-dot');
    const leftArrow = document.querySelector('.showcase-arrow-left');
    const rightArrow = document.querySelector('.showcase-arrow-right');

    if (!track || cards.length === 0) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Track active card via IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
            const idx = Number(entry.target.dataset.cardIndex);
            if (!isNaN(idx)) {
              dots.forEach((dot, di) => {
                if (di === idx) {
                  dot.classList.remove('h-1\\.5', 'w-1\\.5', 'bg-dark\\/20');
                  dot.classList.add('h-2', 'w-2', 'bg-dark');
                } else {
                  dot.classList.remove('h-2', 'w-2', 'bg-dark');
                  dot.classList.add('h-1\\.5', 'w-1\\.5', 'bg-dark\\/20');
                }
              });
            }
          }
        });
      },
      { root: track, threshold: 0.5 }
    );

    cards.forEach((card) => observer.observe(card));

    // Arrow navigation
    function scrollByCard(direction) {
      const card = cards[0];
      if (!card) return;
      const gap = 20;
      const scrollAmount = (card.offsetWidth + gap) * direction;
      track.scrollBy({ left: scrollAmount, behavior: prefersReduced ? 'auto' : 'smooth' });
    }

    if (leftArrow) leftArrow.addEventListener('click', () => scrollByCard(-1));
    if (rightArrow) rightArrow.addEventListener('click', () => scrollByCard(1));

    // Dot click navigation
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const card = cards[i];
        if (card) card.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'nearest', inline: 'center' });
      });
    });
  })();
</script>
