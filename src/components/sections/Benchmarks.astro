---
import { cn } from '../../utils/merge';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const benchmarks = [
  { name: 'GAIA Test', description: 'GPT-4o, full pipeline', value: '70.74', suffix: '%' },
  { name: 'GAIA Validation', description: 'GPT-4o, full pipeline', value: '86', suffix: '%' },
  { name: 'Terminal Bench', description: 'GPT-4o, full pipeline', value: '35.2', suffix: '%' },
  { name: 'IMO 2025', description: 'Mathematical olympiad', value: '5.5', suffix: '/6' },
];
---

<section id="benchmarks" class={cn('section-divider py-10 lg:py-16', className)} aria-labelledby="benchmarks-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-8 text-center lg:mb-12" data-animate>
      <span class="inline-flex items-center rounded-full bg-coral/10 px-3.5 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-coral">
        Performance
      </span>
      <h2 id="benchmarks-heading" class="mt-3 text-3xl font-semibold leading-[0.95] tracking-tight sm:text-4xl lg:text-5xl">
        Built for performance
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-base text-dark/50 sm:text-lg">
        Industry-leading benchmarks across reasoning, coding, and real-world tasks.
      </p>
    </div>

    <!-- Primary stats — card grid -->
    <div class="grid gap-3 sm:grid-cols-2" data-animate data-delay="1">
      {benchmarks.map((b) => (
        <div class="rounded-xl bg-subtle/80 border border-dark/[0.08] p-5 transition-all duration-300 ease-out hover:bg-subtle hover:shadow-md hover:border-dark/[0.12] hover:-translate-y-0.5">
          <div class="flex items-baseline gap-1">
            <span class="text-4xl font-bold tracking-tight">{b.value}</span>
            <span class="text-xl font-semibold text-dark/25">{b.suffix}</span>
          </div>
          <div class="mt-2 text-sm font-semibold text-dark/70">{b.name}</div>
          <div class="mt-0.5 text-xs text-dark/40">{b.description}</div>
        </div>
      ))}
    </div>

    <!-- Footnote -->
    <p class="mt-8 text-center text-[11px] text-dark/30 lg:mt-10">
      All benchmarks tested with specified model configurations. Results may vary based on task complexity.
    </p>
  </div>
</section>
